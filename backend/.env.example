# APP_ENV must be "production" for a Neon/PostgreSQL DATABASE_URL to be
# allowed to start the app at all (see docs/operations/database-safety.md).
# Missing/blank APP_ENV is treated as local/development. Local dev should
# use SQLite and can leave APP_ENV unset or set it to "development":
#   APP_ENV=development
#   DATABASE_URL=sqlite:///./vocab_dev.db
# Production (e.g. Render) must set both:
#   APP_ENV=production
#   DATABASE_URL=postgresql+psycopg://...
APP_ENV=development

# Leave DATABASE_URL empty for local SQLite fallback.
# DATABASE_URL=postgresql://user:password@host:5432/dbname
DATABASE_URL=
JWT_SECRET_KEY=change-me-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://your-frontend-domain.example
# Optional: URL for a normalized JMdict full JSON file. Plain .json and
# .json.zip/.zip URLs are supported. Do not put sha256:... hash text here.
# The backend downloads it at startup only when the local full dictionary file
# is missing.
JMDICT_FULL_JSON_URL=
# Optional: custom local path for the full dictionary JSON file.
JMDICT_FULL_JSON_PATH=
# Optional: URL for a Kaikki/Wiktionary-derived English-to-Korean full JSON
# file. Plain .json, .json.gz/.gz, and .json.zip/.zip URLs are supported. Do
# not put a real URL or secret value here; leave empty to use the committed
# en_ko_sample.json fallback.
EN_KO_DICTIONARY_URL=
# Optional: custom local path for the English-to-Korean full dictionary file.
EN_KO_DICTIONARY_PATH=
# Backward-compatible alias also supported:
# CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Optional: 국립국어원 한국어기초사전/우리말샘 Open API key, used only by the
# offline scripts/fetch_krdict_api.py preprocessing script (never at runtime).
# KRDICT_API_KEY is also accepted. Do not commit a real key.
KRDIC_API_KEY=
# Optional: URL for a pre-built krdict reverse index JSON file (generated
# offline by scripts/build_krdict_reverse_index.py, never at runtime). Plain
# .json, .json.gz/.gz, and .json.zip/.zip URLs are supported. Do not put a
# real URL here; leave empty to use the committed krdict_reverse_sample.json
# fallback.
KRDIC_REVERSE_URL=
# Optional: custom local path for the krdict reverse index full file.
KRDIC_REVERSE_PATH=
